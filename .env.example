# ── Gemini 2.5 Pro ──────────────────────────────────────────────────────────
# Required when using the Gemini model.
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── OpenAI (Whisper + GPT-4o) ───────────────────────────────────────────────
# Required when using the Whisper model.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# ── Sarvam AI ────────────────────────────────────────────────────────────────
# Required when using the Sarvam model (saarika:v2 + saaras:v1).
# Get from: https://dashboard.sarvam.ai
SARVAM_API_KEY="YOUR_SARVAM_API_KEY"

# ── App URL (injected automatically in AI Studio) ───────────────────────────
APP_URL="http://localhost:3000"

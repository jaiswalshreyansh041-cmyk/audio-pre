# ── All API Keys ─────────────────────────────────────────────────────────────
# Add these same keys as Environment Variables in your Vercel project settings.

# Gemini (used by SunLiya.AI + Evaluator Gemini model)
# Get from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# OpenAI — Whisper-1 + GPT-4o (Evaluator Whisper model)
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Sarvam AI — saarika:v2 + saaras:v1 (Evaluator Sarvam model)
# Get from: https://dashboard.sarvam.ai
VITE_SARVAM_API_KEY="YOUR_SARVAM_API_KEY"
